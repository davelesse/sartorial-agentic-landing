# ═══════════════════════════════════════════════════════════
# SARTORIAL AGENTIC — Environment Variables
# Copier vers .env et remplir les valeurs
# ⚠️  NE JAMAIS COMMITER LE FICHIER .env
# ═══════════════════════════════════════════════════════════

# ── APP ──
APP_SECRET_KEY=your-super-secret-key-minimum-32-chars-change-this
APP_ENV=development
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# ── JWT ──
JWT_SECRET=your-jwt-secret-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── DATABASE ──
POSTGRES_USER=sartorial
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=sartorial_agentic

# ── REDIS ──
REDIS_PASSWORD=change-this-redis-password

# ── STRIPE ──
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── ANTHROPIC (Claude API) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── RESEND (Emails) ──
RESEND_API_KEY=re_...

# ── DOMAIN ──
DOMAIN=sartorial-agentic.ai
CORS_ORIGINS=https://sartorial-agentic.ai

# ── NEXT.JS ──
NEXT_TELEMETRY_DISABLED=1

# ── CELERY ──
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300

# ── BACKUPS ──
BACKUP_RETENTION_DAYS=30
S3_BACKUP_BUCKET=

# ── SENTRY (optionnel) ──
SENTRY_DSN=
